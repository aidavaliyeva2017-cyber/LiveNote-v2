{
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-native",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": [
      "jest",
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "jest.config.js"
  ],
  "extends": "expo/tsconfig.base"
}
